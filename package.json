{
  "name": "lifeos",
  "version": "1.0.0",
  "description": "Your personal operating system for everyday life",
  "main": "electron/main.js",
  "scripts": {
    "electron": "electron .",
    "electron:dist": "electron-builder --linux",
    "cap:sync": "npx cap sync android"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.cadger808.lifeos",
    "productName": "LifeOS",
    "linux": {
      "target": ["AppImage", "rpm"],
      "category": "Utility"
    },
    "files": ["index.html","app.js","notifications.js","api-client.js","avatar-widget.js","share-widget.js","manifest.json","sw.js","offline.html","icons/**","electron/**"]
  }
}
